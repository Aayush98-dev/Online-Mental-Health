rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User profiles
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false; // Users shouldn't be listable normally
      allow create: if isOwner(userId) && 
                      incoming().uid == userId &&
                      incoming().email is string &&
                      incoming().createdAt == request.time;
      allow update: if isOwner(userId) && 
                      incoming().uid == existing().uid &&
                      incoming().updatedAt == request.time &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']);
    }

    // Emotion Logs
    match /emotionLogs/{logId} {
      allow read, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
                      incoming().userId == request.auth.uid &&
                      incoming().timestamp == request.time;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Saved Resources
    match /savedResources/{resourceId} {
      allow read, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
                      incoming().userId == request.auth.uid &&
                      incoming().savedAt == request.time;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Activity Logs
    match /activityLogs/{logId} {
      allow read, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
                      incoming().userId == request.auth.uid &&
                      incoming().timestamp == request.time;
    }

    // Appointments
    match /appointments/{appointmentId} {
      allow read, list: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && 
                      incoming().userId == request.auth.uid &&
                      incoming().status == 'pending' &&
                      incoming().createdAt == request.time;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['status', 'date']) &&
                      (incoming().status in ['pending', 'cancelled']);
    }

    // Therapists (Publicly readable)
    match /therapists/{therapistId} {
      allow read, list: if isSignedIn();
      allow write: if false; // Managed via admin/server only
    }
  }
}
